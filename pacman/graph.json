    {
      "id": "device:pacman_state.pacman/maincpu",
      "label": "Device",
      "props": {
        "type": "Z80",
        "tag": "maincpu",
        "clock": 3072000,
        "config": [
          "Z80(config, m_maincpu, 18.432_MHz_XTAL / 6)",
          "m_maincpu->set_addrmap(AS_PROGRAM, &pacman_state::pacman_map)",
          "m_maincpu->set_addrmap(AS_IO, &pacman_state::writeport)",
          "m_maincpu->set_irq_acknowledge_callback(FUNC(pacman_state::interrupt_vector_r))"
        ]
      }
    },
    {
      "id": "device:pacman_state.pacman/mainlatch",
      "label": "Device",
      "props": {
        "type": "LS259",
        "tag": "mainlatch",
        "clock": null,
        "config": [
          "LS259(config, m_mainlatch)",
          "m_mainlatch->q_out_cb<0>().set(FUNC(pacman_state::irq_mask_w))",
          "m_mainlatch->q_out_cb<1>().set(\"namco\", FUNC(namco_wsg_device::sound_enable_w))",
          "m_mainlatch->q_out_cb<3>().set(FUNC(pacman_state::flipscreen_w))",
          "m_mainlatch->q_out_cb<7>().set(FUNC(pacman_state::coin_counter_w))"
        ]
      }
    },
    {
      "id": "device:pacman_state.pacman/watchdog",
      "label": "Device",
      "props": {
        "type": "WATCHDOG_TIMER",
        "tag": "watchdog",
        "clock": null,
        "config": [
          "WATCHDOG_TIMER(config, m_watchdog)",
          "m_watchdog->set_vblank_count(\"screen\", 16)"
        ]
      }
    },
    {
      "id": "device:pacman_state.pacman/gfxdecode",
      "label": "Device",
      "props": {
        "type": "GFXDECODE",
        "tag": "gfxdecode",
        "clock": null,
        "config": [
          "GFXDECODE(config, m_gfxdecode, m_palette, gfx_pacman)"
        ],
        "clockExpr": "m_palette, gfx_pacman"
      }
    },
    {
      "id": "device:pacman_state.pacman/palette",
      "label": "Device",
      "props": {
        "type": "PALETTE",
        "tag": "palette",
        "clock": null,
        "config": [
          "PALETTE(config, m_palette, FUNC(pacman_state::pacman_palette), 128 * 4, 32)"
        ],
        "clockExpr": "FUNC(pacman_state::pacman_palette), 128 * 4, 32"
      }
    },
    {
      "id": "device:pacman_state.pacman/screen",
      "label": "Device",
      "props": {
        "type": "SCREEN",
        "tag": "screen",
        "clock": null,
        "config": [
          "SCREEN(config, m_screen, SCREEN_TYPE_RASTER)",
          "m_screen->set_raw(18.432_MHz_XTAL / 3, 384, 0, 288, 264, 0  , 224  )",
          "m_screen->set_screen_update(FUNC(pacman_state::screen_update_pacman))",
          "m_screen->set_palette(m_palette)",
          "m_screen->screen_vblank().set(FUNC(pacman_state::vblank_irq))"
        ],
        "clockExpr": "SCREEN_TYPE_RASTER",
        "screenRaw": [
          6144000,
          384,
          0,
          288,
          264,
          0,
          224
        ]
